NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
MONGODB_URI=mongodb://127.0.0.1:27017/kyc-auth-db
BANK_DATABASE_URL=postgresql://postgres:<percent-encoded-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5000
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
UPLOAD_DIR=uploads

# Twilio SMS OTP.
# API Key SID usually starts with SK. Account SID starts with AC.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_FROM_PHONE=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_OTP_TTL_MINUTES=5
TWILIO_DEV_OTP=123456
TWILIO_SHOW_OTP_IN_RESPONSE=true

# Firebase Admin SDK.
# Use either GOOGLE_APPLICATION_CREDENTIALS with a service-account JSON path
# or provide these fields directly.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
